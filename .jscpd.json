{
  "threshold": 15,
  "reporters": ["html", "markdown"],
  "format": ["javascript", "typescript", "tsx", "css", "sql"],
  "ignore": [
    "**/node_modules/**",
    "**/.next/**",
    "**/out/**",
    "**/dist/**",
    "**/build/**",
    "**/.git/**",
    "**/.github/**",
    "*.md",
    "**/*.md",
    "*.json",
    "**/*.json",
    "*.yml",
    "**/*.yml",
    "*.yaml",
    "**/*.yaml",
    "*.map",
    "**/*.map"
  ]
}
